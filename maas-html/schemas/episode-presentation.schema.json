{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maas.local/schemas/episode-presentation.schema.json",
  "title": "MAAS episode media presentation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "characters", "places"],
  "properties": {
    "schemaVersion": {"const": "2.0"},
    "characters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "position"],
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "position": {"enum": ["izquierda", "derecha"]}
        }
      }
    },
    "places": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "pattern": "^[a-z0-9-]+$"}
    }
  }
}
