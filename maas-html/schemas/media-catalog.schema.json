{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maas.local/schemas/media-catalog.schema.json",
  "title": "MAAS canonical media catalog",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "rightsProfiles", "assets"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "rightsProfiles": {"type": "object"},
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "sourcePath", "sha256", "mimeType", "allowedForPublish"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "type": {"type": "string"},
          "sourcePath": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "mimeType": {"type": "string"},
          "allowedForPublish": {"type": "boolean"},
          "characterId": {"type": "string"},
          "emotion": {"type": "string"},
          "gaze": {"type": ["string", "null"]},
          "placeId": {"type": "string"},
          "orientation": {"type": "string"},
          "layout": {"type": "string"}
        }
      }
    }
  }
}
