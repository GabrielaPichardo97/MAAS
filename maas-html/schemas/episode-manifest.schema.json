{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maas.local/schemas/episode-manifest.schema.json",
  "title": "MAAS compiled episode",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "episodeId", "title", "language", "status", "seed", "profile", "orientations", "characters", "assets", "assetUrls", "audioPolicy", "subtitleTracks", "subtitles", "interactions", "generation", "timeline", "durationMs", "warnings"],
  "properties": {
    "schemaVersion": {"enum": ["1.0", "2.0", "2.1"]},
    "episodeId": {"type": "string"},
    "title": {"type": "string"},
    "language": {"type": "string"},
    "status": {"enum": ["draft", "ready", "published"]},
    "seed": {"type": "integer", "minimum": 0},
    "profile": {"enum": ["legacy-v1", "canonical-v1", "canonical-v2"]},
    "orientations": {"type": "array", "items": {"enum": ["landscape", "portrait"]}, "minItems": 1, "uniqueItems": true},
    "characters": {"type": "object", "additionalProperties": {"type": "string"}},
    "assets": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "assetUrls": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^/assets/[a-f0-9]{64}\\.[A-Za-z0-9]+$"}},
    "audioPolicy": {"type": "object"},
    "subtitleTracks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/subtitleTrack"}},
    "subtitles": {"type": "array", "items": {"$ref": "#/$defs/subtitleCue"}},
    "interactions": {"type": "array", "items": {"$ref": "#/$defs/interaction"}},
    "generation": {"$ref": "#/$defs/generation"},
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "startMs", "durationMs"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["scene", "dialogue", "sfx", "transition", "advice", "ending"]},
          "startMs": {"type": "integer", "minimum": 0},
          "durationMs": {"type": "integer", "minimum": 0},
          "effect": {"$ref": "#/$defs/legacyEffect"},
          "effects": {"type": "array", "maxItems": 3, "items": {"$ref": "#/$defs/effectInstance"}}
          ,"media": {
            "type": "object",
            "required": ["spriteAssetId", "backgroundAssetId", "mirrorX", "layout", "fallbackApplied"],
            "properties": {
              "spriteAssetId": {"type": "string"},
              "backgroundAssetId": {"type": "string"},
              "mirrorX": {"type": "boolean"},
              "layout": {"enum": ["landscape-character-left", "landscape-character-right"]},
              "fallbackApplied": {"type": ["object", "null"]}
            }
          }
        }
      }
    },
    "durationMs": {"type": "integer", "minimum": 0},
    "warnings": {"type": "array", "items": {"type": "object"}}
  },
  "$defs": {
    "legacyEffect": {
      "type": "object", "additionalProperties": false, "required": ["code", "intensity", "tremor"],
      "properties": {"code": {"enum": ["ES", "ZI", "ZO", "PA-I", "PA-D", "TI-A", "TI-B", "PP"]}, "intensity": {"type": "number", "exclusiveMinimum": 0}, "target": {"type": ["string", "null"]}, "tremor": {"type": "boolean"}}
    },
    "effectInstance": {
      "type": "object", "additionalProperties": false, "required": ["id", "role", "intensity", "startOffsetMs", "durationMs", "params"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*\\.[a-z0-9]+(?:-[a-z0-9]+)*\\.[a-z0-9]+(?:-[a-z0-9]+)*\\.[a-z0-9]+(?:-[a-z0-9]+)*\\.v[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "role": {"enum": ["dominant", "support", "finish"]}, "intensity": {"type": "number", "minimum": 0, "maximum": 1}, "startOffsetMs": {"type": "integer", "minimum": 0}, "durationMs": {"type": "integer", "minimum": 0}, "target": {"type": ["string", "null"], "enum": ["frame", "background", "speaker", null]}, "params": {"type": "object"}
      }
    },
    "subtitleTrack": {
      "type": "object", "additionalProperties": false, "required": ["id", "kind", "format", "language", "label", "url", "sha256"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "kind": {"const": "subtitles"},
        "format": {"const": "webvtt"},
        "language": {"type": "string"},
        "label": {"type": "string", "minLength": 1},
        "url": {"type": "string", "pattern": "^/episodes/[a-z0-9]+(?:-[a-z0-9]+)*/subtitles\\.[a-z0-9-]+\\.vtt$"},
        "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "subtitleCue": {
      "type": "object", "additionalProperties": false, "required": ["id", "cueId", "startMs", "endMs", "speakerLabel", "text", "kind"],
      "properties": {
        "id": {"type": "string", "pattern": "^subtitle-[0-9]{4}$"},
        "cueId": {"type": "string"},
        "startMs": {"type": "integer", "minimum": 0},
        "endMs": {"type": "integer", "minimum": 0},
        "speakerLabel": {"type": "string"},
        "text": {"type": "string", "minLength": 1},
        "kind": {"enum": ["dialogue", "sound", "transition", "advice"]}
      }
    },
    "interaction": {
      "type": "object", "additionalProperties": false, "required": ["id", "type", "label", "startMs", "durationMs", "target", "action"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "type": {"enum": ["button", "hotspot"]},
        "label": {"type": "string", "minLength": 1},
        "startMs": {"type": "integer", "minimum": 0},
        "durationMs": {"type": "integer", "exclusiveMinimum": 0},
        "target": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/interactionTarget"}]},
        "action": {"$ref": "#/$defs/interactionAction"}
      }
    },
    "interactionTarget": {
      "type": "object", "additionalProperties": false, "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {"type": "number", "minimum": 0, "maximum": 1},
        "y": {"type": "number", "minimum": 0, "maximum": 1},
        "width": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "height": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}
      }
    },
    "interactionAction": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["type"], "properties": {"type": {"const": "pause"}}},
        {"type": "object", "additionalProperties": false, "required": ["type", "positionMs"], "properties": {"type": {"const": "seek"}, "positionMs": {"type": "integer", "minimum": 0}}},
        {"type": "object", "additionalProperties": false, "required": ["type", "panelId"], "properties": {"type": {"const": "openPanel"}, "panelId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}}},
        {"type": "object", "additionalProperties": false, "required": ["type", "url"], "properties": {"type": {"const": "openUrl"}, "url": {"type": "string", "pattern": "^/(?!/)(?!.*\\.\\.).*"}}},
        {"type": "object", "additionalProperties": false, "required": ["type", "event"], "properties": {"type": {"const": "emit"}, "event": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "detail": {"type": "object"}}}
      ]
    },
    "generation": {
      "type": "object", "additionalProperties": false, "required": ["schemaVersion", "policy", "determinism", "aiRuntime", "htmlFirst", "seed", "toolchain", "inputHashes"],
      "properties": {
        "schemaVersion": {"const": "1.0"},
        "policy": {"const": "approved-json-bit-for-bit"},
        "determinism": {"const": "bit-for-bit-after-approval"},
        "aiRuntime": {"const": "forbidden-during-build"},
        "htmlFirst": {"const": true},
        "seed": {"type": "integer", "minimum": 0},
        "toolchain": {"type": "object", "additionalProperties": {"type": "string"}},
        "inputHashes": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
      }
    }
  },
  "allOf": [
    {"if": {"properties": {"schemaVersion": {"enum": ["2.0", "2.1"]}}}, "then": {"properties": {"profile": {"const": "canonical-v2"}}}},
    {"if": {"properties": {"profile": {"const": "canonical-v2"}}}, "then": {"properties": {"schemaVersion": {"enum": ["2.0", "2.1"]}}}}
  ]
}
